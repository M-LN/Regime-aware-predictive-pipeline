# Environment Configuration Template
# Copy to .env and fill in your values

# Environment
ENVIRONMENT=development
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
# API Key (optional). When set, require X-API-Key header on inference endpoints.
# API_KEY=your_api_key_here
# Rate limiting (per IP)
# RATE_LIMIT=60/minute
# API Key (optional). When set, require X-API-Key header on inference endpoints.
# API_KEY=your_api_key_here

# Data Configuration
RAW_DATA_PATH=data/raw
FEATURE_STORE_PATH=data/features
MODEL_REGISTRY_PATH=data/models

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=regime-predictor
MLFLOW_BACKEND_STORE_URI=file:///data/mlflow
# MLflow Model Registry
# MLFLOW_REGISTRY_ENABLED=false
# MLFLOW_REGISTRY_STAGE=Production
# MLFLOW_REGISTRY_MODEL_A=regime_a_model
# MLFLOW_REGISTRY_MODEL_B=regime_b_model
# MLFLOW_REGISTRY_MODEL_C=regime_c_model
# MLflow Registry Promotion (training)
# MLFLOW_REGISTRY_PROMOTE=false
# MLFLOW_REGISTRY_NAME_TEMPLATE=regime_{regime_id}_{model_name}

# Data Source Configuration (Energi Data Service)
# Set EDS_BASE_URL to enable real ingestion. If empty, mock data is used.
# EDS_BASE_URL=https://api.energidataservice.dk
# EDS_API_KEY=your_api_key_here
# EDS_TIMEOUT=30
# EDS_ENERGY_ENDPOINT=/dataset/DeclarationProduction
# EDS_PRICE_ENDPOINT=/dataset/Elspotprices
# EDS_TIMESTAMP_FIELD=HourUTC
# EDS_START_PARAM=start
# EDS_END_PARAM=end
# EDS_ENERGY_FIELD_MAP={"energy_production":"Production_MWh"}
# EDS_PRICE_FIELD_MAP={"price":"SpotPriceDKK"}
# EDS_ENERGY_EXTRA_PARAMS={"filter":{"PriceArea":["DK1"]}}
# EDS_PRICE_EXTRA_PARAMS={"filter":{"PriceArea":["DK1"]}}
# EDS_EXTRA_PARAMS={"limit":100}

# Weather Configuration (Open-Meteo)
# WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
# WEATHER_LATITUDE=55.6761
# WEATHER_LONGITUDE=12.5683
# WEATHER_TIMEZONE=Europe/Copenhagen
# WEATHER_HOURLY_FIELDS=temperature_2m,wind_speed_10m
# WEATHER_TIMEOUT=30

# Ingestion Scheduling
# INGEST_LOOKBACK_HOURS=24
# INGEST_FFILL_COLUMNS=energy_production,price,temperature,wind_speed
# INGEST_FFILL_LIMIT=2

# Feature Engineering
ROLLING_WINDOWS=1,6,24
VOLATILITY_WINDOWS=6,24
NORMALIZATION_METHOD=minmax

# Regime Detection
N_REGIMES=3
HMM_N_ITER=100
HMM_RANDOM_STATE=42

# Model Configuration
REGIME_A_MODEL=xgboost
REGIME_B_MODEL=lstm
REGIME_C_MODEL=random_forest
TEST_SIZE=0.2

# Monitoring
ENABLE_DRIFT_DETECTION=true
DRIFT_DETECTION_METHOD=kl_divergence
DRIFT_THRESHOLD=0.3
# Drift auto-check (API)
DRIFT_AUTO_CHECK_ENABLED=true
DRIFT_CHECK_INTERVAL_SECONDS=300
# Drift alerting webhook
# ALERT_WEBHOOK_URL=https://hooks.example.com/your-webhook
# ALERT_MIN_SEVERITY=medium
# ALERT_TIMEOUT_SECONDS=5
