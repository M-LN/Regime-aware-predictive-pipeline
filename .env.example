# Environment Configuration Template
# Copy to .env and fill in your values

# Environment
ENVIRONMENT=development
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Data Configuration
RAW_DATA_PATH=data/raw
FEATURE_STORE_PATH=data/features
MODEL_REGISTRY_PATH=data/models

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=regime-predictor
MLFLOW_BACKEND_STORE_URI=file:///data/mlflow

# Data Source Configuration (Energi Data Service)
# Set EDS_BASE_URL to enable real ingestion. If empty, mock data is used.
# EDS_BASE_URL=https://api.example.com
# EDS_API_KEY=your_api_key_here
# EDS_TIMEOUT=30
# EDS_ENERGY_ENDPOINT=/energy
# EDS_WEATHER_ENDPOINT=/weather
# EDS_PRICE_ENDPOINT=/prices
# EDS_TIMESTAMP_FIELD=timestamp
# EDS_START_PARAM=start
# EDS_END_PARAM=end

# Ingestion Scheduling
# INGEST_LOOKBACK_HOURS=24

# Feature Engineering
ROLLING_WINDOWS=1,6,24
VOLATILITY_WINDOWS=6,24
NORMALIZATION_METHOD=minmax

# Regime Detection
N_REGIMES=3
HMM_N_ITER=100
HMM_RANDOM_STATE=42

# Model Configuration
REGIME_A_MODEL=xgboost
REGIME_B_MODEL=lstm
REGIME_C_MODEL=random_forest
TEST_SIZE=0.2

# Monitoring
ENABLE_DRIFT_DETECTION=true
DRIFT_DETECTION_METHOD=kl_divergence
DRIFT_THRESHOLD=0.3
